@using Lister.Application.DTOs.ToDoItems
@using Lister.Application.Extensions
@model List<ToDoTableDto>

@if (!Model.Any())
{
    <p>No Items are available</p>
}
else
{
    <div>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Done</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <a asp-page="/Items/Detail" asp-route-id="@item.Id">
                                @item.Title
                            </a>
                        </td>
                        <td>
                            <input type="checkbox" asp-for="@item.IsCompleted" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}